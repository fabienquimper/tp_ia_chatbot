# Étape 00 — Variables d'environnement (partagées par toutes les étapes)
# Copiez ce fichier en .env et remplissez vos valeurs

# Clé API OpenAI (obligatoire pour le mode cloud)
OPENAI_API_KEY=sk-your-key-here

# Mode de connexion par défaut : "cloud" (OpenAI) ou "local" (LM Studio)
MODE=local

# --- Config CLOUD ---
#CLOUD_MODEL=gpt-4o-mini

# --- Config LOCAL (LM Studio) ---
# 2. local — gpt-oss-20b (localhost)
#LOCAL_BASE_URL=http://localhost:1234/v1
#LOCAL_MODEL=openai/gpt-oss-20b

# 3. local_mistral3 — ministral-3-3b (localhost)
#LOCAL_BASE_URL=http://localhost:1234/v1
#LOCAL_MODEL=mistralai/ministral-3-3b

# 4. reseau_ministral14b — ministral-3-14b-reasoning (réseau 192.168.1.141) ← actif
LOCAL_BASE_URL=http://192.168.1.141:1234/v1
LOCAL_MODEL=mistralai/ministral-3-14b-reasoning

# 5. reseau_gpt_oss_20b — gpt-oss-20b (réseau 192.168.1.141)
#LOCAL_BASE_URL=http://192.168.1.141:1234/v1
#LOCAL_MODEL=gpt-oss-20b
