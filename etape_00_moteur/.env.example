# Étape 00 — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs

# Clé API OpenAI (obligatoire pour le mode cloud)
OPENAI_API_KEY=sk-your-key-here

# Mode de connexion : "cloud" (OpenAI) ou "local" (LM Studio)
MODE=cloud

# Modèle local LM Studio (optionnel, utilisé si MODE=local)
LOCAL_MODEL=mistral-7b-instruct
