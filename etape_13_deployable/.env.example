# ══════════════════════════════════════════════════════════════════════════════
# Étape 13 — Variables d'environnement
# Copier en .env et remplir les valeurs (ne jamais committer .env !)
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini
MODE=cloud                           # cloud | local

# Mode local (LM Studio / Ollama)
LOCAL_BASE_URL=http://host.docker.internal:1234/v1
LOCAL_MODEL=mistral-7b-instruct

# ── RAG ───────────────────────────────────────────────────────────────────
CHROMA_PATH=/app/data/chroma_db
RAG_COLLECTION=chatbot_docs
RAG_TOP_K=3

# ── Base de données ───────────────────────────────────────────────────────
DB_PATH=/app/data/chat.db

# ── Sécurité ──────────────────────────────────────────────────────────────
# IMPORTANT : Changer cette valeur en production !
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production-must-be-very-long

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Monitoring ────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-this-grafana-password

# ── Domaine (production) ──────────────────────────────────────────────────
DOMAIN=your-domain.com

# ── Registry Docker (optionnel — requis pour ./build.sh --push) ───────────
# Exemples : ghcr.io/monusername | registry.hub.docker.com/monuser | monserveur:5000
REGISTRY=ghcr.io/monorg
REGISTRY_USER=username
REGISTRY_TOKEN=your-token-here
