# ══════════════════════════════════════════════════════════════════════════════
# Étape 14 — Variables d'environnement
# Copier en .env et remplir les valeurs (ne jamais committer .env !)
#
# La plupart des variables viennent de l'étape 13.
# Copier d'abord etape_13_deployable/.env ici, puis ajouter ce qui suit.
# ══════════════════════════════════════════════════════════════════════════════

# ── Hérité de l'étape 13 ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini
MODE=cloud
LOCAL_BASE_URL=http://host.docker.internal:1234/v1
LOCAL_MODEL=mistral-7b-instruct
SECRET_KEY=change-this-secret-key-in-production-must-be-very-long
GRAFANA_PASSWORD=change-this-grafana-password
ALLOWED_ORIGINS=https://your-domain.com

# ── Registry Docker (même valeurs que l'étape 13) ─────────────────────────────
REGISTRY=ghcr.io/fabienquimper
REGISTRY_USER=fabienquimper
REGISTRY_TOKEN=your-token-here

# ── Image à déployer ──────────────────────────────────────────────────────────
# Laisser 'latest' pour toujours prendre la dernière image poussée
# Ou spécifier un SHA précis : IMAGE_TAG=b5b88ec
IMAGE_TAG=latest

# ── Déploiement VPS (optionnel — requis pour make deploy-vps) ─────────────────
DEPLOY_HOST=user@your-server.com
DEPLOY_DIR=/opt/chatbot

# ── Domaine production ────────────────────────────────────────────────────────
DOMAIN=your-domain.com
